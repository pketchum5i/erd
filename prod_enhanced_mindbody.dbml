  PROMOTIONID number [ref: > PROMOTIONS.PROMOTIONID]
  PROMOTIONCODE text
  PROMOTIONNAME text
  DISCOUNT float
  DISCAMT number
  PRORATEAMOUNT number
  UNITPRICE number
  SDPAYMENTAMT number
  PRODUCTID float [ref: > PRODUCTS.PRODUCTID]
  BARCODEID text
  DESCRIPTION text
  CATEGORYID number [ref: > CATEGORIES.CATEGORYID]
  CATEGORY2ID number
  SUBCATEGORYID number
  CATEGORY text
  PRODUCT_DATACLEANSTATUS text
  CATEGORY_DATACLEANSTATUS text
