}

Table PAYMENTS {
  PAYMENTID number [pk]
  STUDIOID number [pk, ref: > STUDIOS.STUDIOID]
  SALEID number [ref: > SALES.SALEID]
  PAYMENTDISCOUNT number
  PAYMENTAMOUNT number
  PAYMENTTAX number
  PAYMENTTYPEID number [ref: > PAYMENT_TYPES.PAYMENTTYPEID]
  PAYMENT_TYPE text
  CASHEQ boolean
  HAS_CASH_ORIGIN boolean
  REAL_LIABILITY boolean
  CCTRANSID number [ref: > CCTRANS.TRANSACTIONNUMBER]
  CCSWIPED boolean
  CCTRANSACTIONSTATUS text
  CCSETTLED boolean
  DEBITCARDIDS array
  DEBITCARDEXTERNALID text
  PAYMENTNOTES text
  CREATEDDATETIMEUTC timestamp_tz
  MODIFIEDDATETIMEUTC timestamp_tz
  
  Note: 'Payment methods used for sales'
}

Table SDPAYMENTS {
  SDPAYMENTID number [pk]
  STUDIOID number [pk, ref: > STUDIOS.STUDIOID]
  PAYMENTID number [ref: > PAYMENTS.PAYMENTID]
  PAYMENT_TYPE text
  CASHEQ boolean
  HAS_CASH_ORIGIN boolean
  REAL_LIABILITY boolean
  CCTRANSID number
  CCSWIPED boolean
  CCTRANSACTIONSTATUS text
  CCSETTLED boolean
  DEBITCARDIDS array
  DEBITCARDEXTERNALID text
  SDID number [ref: > SALES_DETAILS.SDID]
  DISCAMT number
  SDPAYMENTAMOUNT number
  ITEMTAX1 number
  ITEMTAX2 number
  ITEMTAX3 number
  ITEMTAX4 number
  ITEMTAX5 number
  RECONCILEDFORAMOUNT number
  RECONCILEDWITHAMOUNT number
