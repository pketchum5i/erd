// DBML Schema for PROD_ENHANCED.MINDBODY
// MindBody business management data - fitness/wellness studio operations
// Generated from Snowflake schema

Project prod_enhanced_mindbody {
  database_type: 'Snowflake'
  Note: '''
    MindBody business management system data for fitness/wellness studios.
    Contains client information, appointments, sales transactions, memberships,
    contracts, payments, and scheduling data.
  '''
}

// ============================================================================
// CORE REFERENCE TABLES
// ============================================================================

Table STUDIOS {
  STUDIOID number [pk, note: 'Unique studio identifier']
  STUDIONAME text
  CANONICAL_NAME text
  ISFRANCHISE boolean
  STUDIOSHORT text
  BUSINESSDESCRIPTION text
  LOCALESTR text
  SITECREATIONDATE date
  REGIONSHORT text
  CITY text
  STATEPROVCODE text
  COUNTRYCODE text
  BILLMBOCLTID number
  TIMEZONEID text
  TIMEZONEOFFSET number
  TIMEZONEOFFSETMIN number
  AUTOPAYRETRYDAYS number
  ENABLEACH boolean
  TAXINCLUSIVEPRICES boolean
  SPAFINDEROPTIN boolean
  SPAFINDERGIFTCARD boolean
  CCPROCESSOR text
  ALLOWMINDBODYEMAILOPTIN boolean
  SHOWINVENTORYTOTHIRDPARTY boolean
  REGIONID number
  CORPREGIONID number
  TEMPLATESITE boolean
  DEMOSITE boolean
  SITEDEACTIVATED boolean
  AUTOEMAILREPLYNAME text
  AUTOEMAILREPLYADDRESS text
  DELETED boolean
  DATEDELETED date
  CREATEDDATETIMEUTC timestamp_tz
  MODIFIEDDATETIMEUTC timestamp_tz
  
  Note: 'Master table of MindBody studio sites'
}

Table LOCATIONS {
  LOCATIONID number [pk]
  STUDIOID number [pk, ref: > STUDIOS.STUDIOID]
  LOCATIONNAME text
  CANONICAL_NAME text
  TAX1 float
  TAX2 float
  TAX3 float
  TAX4 float
  TAX5 float
  LABELTAX1 text
  LABELTAX2 text
  LABELTAX3 text
  LABELTAX4 text
  LABELTAX5 text
  ENABLETAX1 boolean
  ENABLETAX2 boolean
  ENABLETAX3 boolean
  ENABLETAX4 boolean
  ENABLETAX5 boolean
  PHONE text
  EMAIL text
  CONTACTNAME text
  ADDRESS text
  ADDRESSLN2 text
  CITY text
  STATEPROVCODE text
  POSTALCODE text
  COUNTRY text
  LONGITUDE float
  LATITUDE float
  GEOLOCATION geography
  ACTIVE boolean
  INVACTIVE boolean
  TAXID text
  MBACCOUNTNUMBER text
  CREATEDDATETIMEUTC timestamp_tz
  MODIFIEDDATETIMEUTC timestamp_tz
  
  Note: 'Physical locations within each studio'
}

