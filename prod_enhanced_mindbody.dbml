}

Table PAYMENT_DATA {
  PMTREFNO number [pk, note: 'Payment reference number']
  STUDIOID number [pk, ref: > STUDIOS.STUDIOID]
  LOCATIONID number [ref: > LOCATIONS.LOCATIONID]
  SALEID number [ref: > SALES.SALEID]
  PAYMENTDATE date
  ACTIVEDATE date [note: 'First day payment can be used for visits']
  EXPDATE date [note: 'Day after last valid use date']
  PRODUCTID float [ref: > PRODUCTS.PRODUCTID]
  CATEGORY text
  PRODUCT_DATACLEANSTATUS text
  CATEGORY_DATACLEANSTATUS text
  TYPEPURCH text
  PAYMENTAMOUNT number
  PAYMENTMETHOD number
  CLIENTCREDIT number
  RETURNED boolean
  NUMCLASSES number [note: 'Original purchase count for lesson packages']
  REMAINING number
  REALREMAINING number [note: 'Remaining lessons (may be manually decremented)']
  DURATION number
  DURATIONUNIT text
  SERIESTYPE text
  SERVICETYPE text
  SERVICETYPE_DATACLEANSTATUS text
  CLASSID number
  CLIENTID number [ref: > CLIENTS.CLIENTID]
  CLIENTCONTRACTID number [ref: > CLIENTCONTRACTS.CLIENTCONTRACTID]
  TERMINATIONCLIENTCONTRACTID number
  SOLDBY number
  SCHPERDAY number
  VALUE number
  PMTNOTES text
  SOURCEID number
  PRIORITY number
  MODIFIEDDATETIMEUTC timestamp_tz
  
  Note: '''
    Payment records for studio services. 
    Useful for active membership payments.
    ACTIVEDATE = first day payment can be used.
    EXPDATE = day after last valid use date.
    NUMCLASSES = original lesson package count.
    REALREMAINING = remaining lessons (may be manually decremented).
  '''
}

Table PAYMENT_TYPES {
  PAYMENTTYPEID number [pk]
  STUDIOID number [pk, ref: > STUDIOS.STUDIOID]
  PAYMENT_TYPE text
